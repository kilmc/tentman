{
	"type": "content",
	"label": "Blog Posts",
	"itemLabel": "Blog Post",
	"collection": true,
	"idField": "slug",
	"content": {
		"mode": "directory",
		"path": ".",
		"template": "./post.template.md",
		"filename": "{{slug}}"
	},
	"editorLayout": {
		"aside": ["slug", "date", "author"],
		"asideLabel": "Metadata"
	},
	"blocks": [
		{
			"id": "title",
			"label": "Title",
			"type": "text",
			"required": true,
			"minLength": 5,
			"maxLength": 100
		},
		{ "id": "slug", "label": "Slug", "type": "text", "required": true, "maxLength": 50 },
		{ "id": "date", "label": "Date", "type": "date", "required": true },
		{
			"id": "author",
			"label": "Author",
			"type": "text",
			"required": true,
			"maxLength": 50
		},
		{ "id": "coverImage", "label": "Cover Image", "type": "image" },
		{
			"id": "excerpt",
			"label": "Excerpt",
			"type": "textarea",
			"required": true,
			"minLength": 20,
			"maxLength": 300
		},
		{ "id": "body", "label": "Body", "type": "markdown", "required": true, "minLength": 50 },
		{ "id": "published", "label": "Published", "type": "toggle" }
	]
}

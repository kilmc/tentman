# GitHub OAuth Configuration
# Create a GitHub OAuth App at: https://github.com/settings/developers
# Set Authorization callback URL to: http://localhost:5173/auth/callback (dev) or your production URL
# Optional override. Netlify deploy previews automatically use the main site URL
# as the GitHub callback and relay the user back to the preview after authorization.
GITHUB_OAUTH_CALLBACK_URL=

GITHUB_CLIENT_ID=your_github_oauth_client_id_here
GITHUB_CLIENT_SECRET=your_github_oauth_client_secret_here

{
	"name": "@tentman/workspace",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"packageManager": "pnpm@10.11.1",
	"engines": {
		"node": "^20.19.0 || >=22.12.0"
	},
	"scripts": {
		"dev": "pnpm --filter @tentman/web run dev",
		"build": "pnpm --filter @tentman/web run build",
		"preview": "pnpm --filter @tentman/web run preview",
		"check": "pnpm --filter @tentman/web run check",
		"check:watch": "pnpm --filter @tentman/web run check:watch",
		"format": "pnpm --filter @tentman/web run format",
		"lint": "pnpm --filter @tentman/web run lint",
		"tentman": "pnpm --filter @tentman/cli run tentman --",
		"test:core": "pnpm --filter @tentman/core run test",
		"test:unit": "pnpm --filter @tentman/web run test:unit",
		"test": "pnpm --filter @tentman/web run test"
	}
}

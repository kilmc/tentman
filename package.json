{
	"name": "tentman",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"engines": {
		"node": "^20.19.0 || >=22.12.0"
	},
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json && npm run check:thin-backend",
		"check:thin-backend": "node ./scripts/check-thin-backend.mjs",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"format": "prettier --write .",
		"lint": "prettier --check . && eslint .",
		"test:unit": "vitest",
		"test": "npm run test:unit -- --run"
	},
	"devDependencies": {
		"@eslint/compat": "^1.4.0",
		"@eslint/js": "^9.36.0",
		"@sveltejs/adapter-netlify": "^5.2.3",
		"@sveltejs/kit": "^2.43.2",
		"@sveltejs/vite-plugin-svelte": "^6.2.0",
		"@tailwindcss/vite": "^4.1.13",
		"@types/jsonpath-plus": "^5.0.5",
		"@types/node": "^22",
		"@vitest/browser": "^3.2.4",
		"eslint": "^9.36.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.12.4",
		"globals": "^16.4.0",
		"playwright": "^1.55.1",
		"prettier": "^3.6.2",
		"prettier-plugin-svelte": "^3.4.0",
		"prettier-plugin-tailwindcss": "^0.6.14",
		"svelte": "^5.39.5",
		"svelte-check": "^4.3.2",
		"tailwindcss": "^4.1.13",
		"typescript": "^5.9.2",
		"typescript-eslint": "^8.44.1",
		"vite": "^7.1.7",
		"vitest": "^3.2.4",
		"vitest-browser-svelte": "^1.1.0"
	},
	"dependencies": {
		"@humanspeak/svelte-markdown": "^0.8.13",
		"@octokit/auth-oauth-app": "^9.0.3",
		"@tailwindcss/typography": "^0.5.19",
		"@tiptap/core": "^3.22.3",
		"@tiptap/extension-file-handler": "^3.22.3",
		"@tiptap/extension-image": "^3.22.3",
		"@tiptap/extension-link": "^3.22.3",
		"@tiptap/extension-placeholder": "^3.22.3",
		"@tiptap/markdown": "^3.22.3",
		"@tiptap/starter-kit": "^3.22.3",
		"bits-ui": "^2.17.3",
		"gray-matter": "^4.0.3",
		"jsonpath-plus": "^10.3.0",
		"lucide-svelte": "^1.0.1",
		"octokit": "^5.0.5",
		"svelte-dnd-action": "^0.9.69"
	}
}

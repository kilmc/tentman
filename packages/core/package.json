{
	"name": "@tentman/core",
	"version": "0.1.1",
	"type": "module",
	"description": "Core Tentman content, schema, navigation, and rendering utilities.",
	"license": "UNLICENSED",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/kilmc/tentman.git",
		"directory": "packages/core"
	},
	"homepage": "https://github.com/kilmc/tentman/tree/main/packages/core",
	"bugs": {
		"url": "https://github.com/kilmc/tentman/issues"
	},
	"engines": {
		"node": "^20.19.0 || >=22.12.0"
	},
	"publishConfig": {
		"access": "public"
	},
	"files": [
		"src/**/*.js",
		"src/**/*.d.ts",
		"!src/**/*.test.js",
		"!src/**/*.test-helper.js",
		"!src/fixtures/**",
		"README.md"
	],
	"scripts": {
		"test": "node --test src/*.test.js"
	},
	"exports": {
		".": {
			"types": "./src/index.d.ts",
			"default": "./src/index.js"
		},
		"./assets-config": {
			"types": "./src/index.d.ts",
			"default": "./src/assets-config.js"
		},
		"./content-components": {
			"types": "./src/content-components.d.ts",
			"default": "./src/content-components.js"
		},
		"./navigation-manifest": {
			"types": "./src/navigation-manifest.d.ts",
			"default": "./src/navigation-manifest.js"
		}
	},
	"types": "./src/index.d.ts",
	"dependencies": {
		"gray-matter": "^4.0.3",
		"nunjucks": "^3.2.4"
	}
}
